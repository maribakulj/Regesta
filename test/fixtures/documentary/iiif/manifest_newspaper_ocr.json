        label: "Comment",
        style: {
            display: "inline-block",
            "padding-right": "10px"
        }
      },
      {
        type: "radio",
        name: "feedback_type",
        value: "Correction",
        label: "Correction",
        style: {
            display: "inline-block",
            "padding-right": "10px"
        }
      },
      {
        type: "radio",
        name: "feedback_type",
        value: "Bug",
        label: "Bug",
